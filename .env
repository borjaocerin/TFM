# ==============================
# LaLiga Predictor - Environment
# ==============================
# Rellena estas variables antes de ejecutar:
# docker compose up --build

# API-Football (fixtures, lineups, stats)
API_FOOTBALL_KEY=

# TheOddsAPI (cuotas reales para value betting)
ODDS_API_KEY=cbdc1a3c0f0beda701299431193cc163

# Opcional: fija sportsbook preferido en TheOddsAPI
# Ejemplos comunes: bet365, pinnacle, betfair, unibet
PREFERRED_BOOKMAKER=

# Fuente de cuotas por defecto en simulacion: api o simulated
DEFAULT_ODDS_SOURCE=api

# URL backend para frontend fuera de Docker (opcional)
# En docker-compose ya se inyecta BACKEND_URL=http://backend:8000
BACKEND_URL=http://127.0.0.1:8000

# Variables que usa el backend para fixtures
FIXTURES_API_KEY=*
FIXTURES_API_HOST=v3.football.api-sports.io
FIXTURES_API_URL=https://v3.football.api-sports.io/fixtures?league=140&season={season_start_year}&next=50